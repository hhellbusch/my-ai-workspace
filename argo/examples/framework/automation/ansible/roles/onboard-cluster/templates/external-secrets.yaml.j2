{#
external-secrets.yaml.j2

Template for generating ExternalSecret resources that reference Vault secrets
provisioned during onboarding. These are committed to the cluster's config
directory and deployed by ArgoCD to the spoke cluster.

The External Secrets Operator on the spoke cluster reads the ExternalSecret
and creates a Kubernetes Secret from the Vault data.

Usage: This template is rendered by the Ansible onboarding playbook and
       saved to clusters/<name>/external-secrets.yaml for GitOps deployment.
#}
---
# ExternalSecret: Pull cluster-specific secrets from Vault
# Deployed to the spoke cluster by ArgoCD
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: fleet-cluster-secrets
  namespace: fleet-system
  labels:
    component: fleet-management
    fleet.cluster: {{ cluster_name }}
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: vault-backend
    kind: ClusterSecretStore
  target:
    name: fleet-cluster-secrets
    creationPolicy: Owner
  data:
{% for secret in vault_secrets_to_generate %}
{% if secret.condition | default(true) %}
    - secretKey: {{ secret.name }}
      remoteRef:
        key: {{ vault_secret_path_prefix }}/{{ cluster_name }}/{{ secret.name }}
        property: data
{% endif %}
{% endfor %}
