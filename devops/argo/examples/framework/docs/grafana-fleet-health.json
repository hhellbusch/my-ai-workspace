{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for ArgoCD metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Fleet-wide ArgoCD Application sync status aggregated across all managed clusters and apps.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Fleet Sync Overview",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "count(argocd_app_info{namespace=\"openshift-gitops\"})",
          "legendFormat": "Total Applications"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Synced Applications",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "count(argocd_app_info{namespace=\"openshift-gitops\", sync_status=\"Synced\"})",
          "legendFormat": "Synced"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Out of Sync Applications",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "count(argocd_app_info{namespace=\"openshift-gitops\", sync_status=\"OutOfSync\"})",
          "legendFormat": "OutOfSync"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Degraded / Unknown Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "count(argocd_app_info{namespace=\"openshift-gitops\", health_status=~\"Degraded|Unknown\"})",
          "legendFormat": "Degraded/Unknown"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Sync Status by App",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "count by (name, sync_status, health_status) (argocd_app_info{namespace=\"openshift-gitops\"})",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "name": "Application",
              "sync_status": "Sync Status",
              "health_status": "Health"
            }
          }
        }
      ]
    },
    {
      "title": "Out of Sync Duration (minutes)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "(time() - argocd_app_info{namespace=\"openshift-gitops\", sync_status=\"OutOfSync\"} * 0 + on(name) group_left() (argocd_app_info{namespace=\"openshift-gitops\", sync_status=\"OutOfSync\"} * 0 + 1)) / 60",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "m"
        }
      }
    },
    {
      "title": "Sync Status by Environment",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "count by (sync_status) (argocd_app_info{namespace=\"openshift-gitops\"} * on(name) group_left(label_env) argocd_app_labels{label_env=\"production\"})",
          "legendFormat": "{{sync_status}}"
        }
      ]
    },
    {
      "title": "Sync Operations per Hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(argocd_app_sync_total{namespace=\"openshift-gitops\"}[1h])) by (name) * 3600",
          "legendFormat": "{{name}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["fleet", "argocd", "gitops"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "Fleet Health - ArgoCD Sync Status",
  "uid": "fleet-health-overview"
}
